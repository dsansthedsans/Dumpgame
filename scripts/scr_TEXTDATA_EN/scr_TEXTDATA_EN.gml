	ds_map_add(global.textdata_en, "charamenu_stat_deaths", "DEATHS");
	ds_map_add(global.textdata_en, "charamenu_stat_weapon", "WEAPON");
	ds_map_add(global.textdata_en, "charamenu_stat_armor", "ARMOR");
	
